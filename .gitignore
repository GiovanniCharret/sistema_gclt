# Commitar tudo do projeto (conteúdo, dados, planejamento, manuais, notas).
# Mantidos fora do git apenas artefatos regeneráveis e segredos.

# ── Dependências / build (regeneráveis) ──────────────────
node_modules/
dist/
dist-ssr/
build/
*.local

# ── Python (backend) — regeneráveis ──────────────────────
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# ── Segredos (NÃO versionar) ─────────────────────────────
.env
.env.*
!.env.example
usuarios.json
backend/usuarios.json

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / SO / temporários de Office ──────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?
.DS_Store
Thumbs.db
desktop.ini
~$*
.playwright-mcp/
