# Exemplo de configuração do backend — COPIE para `backend/.env` e preencha.
# O arquivo `.env` real fica FORA do git (segredo); só este `.env.example` é versionado.
# As chaves abaixo são consumidas pelo config.py (pydantic-settings) ao longo dos
# Blocos A–G; nesta sub-fase (A1) nenhuma é obrigatória ainda — o arquivo serve de
# contrato/documentação das variáveis que entram em uso nas próximas sub-fases.

# ── Token de sessão (Bloco B — auth) ─────────────────────
# Chave secreta forte para assinar o token de sessão (gere algo aleatório e longo).
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
# Tempo de vida do token de sessão, em segundos (ex.: 28800 = 8h).
TOKEN_TTL=28800

# ── SMTP / e-mail (Bloco E) ──────────────────────────────
# Host e porta do servidor SMTP.
SMTP_HOST=smtp.exemplo.com.br
SMTP_PORT=587
# Credenciais de envio.
SMTP_USER=usuario@exemplo.com.br
SMTP_PASS=senha-do-smtp
# Remetente exibido nos e-mails.
SMTP_FROM=nao-responder@exemplo.com.br
# Usar STARTTLS (1) ou não (0).
SMTP_TLS=1
# Modo dry-run: 1 = não envia de verdade, só loga o que enviaria (dev/testes).
SMTP_DRYRUN=1
# Lista única e global de destinatários da planilha validada (separados por vírgula).
DESTINATARIOS=destino1@mme.gov.br,destino2@enbpar.gov.br
# E-mail do administrador que recebe os alertas críticos (contrato sem referência).
ALERTA_EMAIL=admin@enbpar.gov.br

# ── Mapas de acesso (Bloco A4/C — filtro por grupo econômico) ─
# Mapa domínio_do_email -> grupo (camada 1). Formato: dominio=GRUPO, separados por vírgula.
ACESSO_DOMINIO_GRUPO=equatorialenergia.com.br=EQUATORIAL,energisa.com.br=ENERGISA,enbpar.gov.br=ENBPAR
# Grupos que enxergam tudo (curinga). Separados por vírgula.
ACESSO_GRUPOS_CURINGA=ENBPAR
